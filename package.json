{
  "name": "nemesis-studio",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node server/index.js",
    "build": "next build",
    "start": "node server/index.js",
    "server": "node server/index.js",
    "electron:dev": "cross-env PORT=8790 electron .",
    "electron:build": "electron-builder --win --x64",
    "electron:pack": "electron-builder --dir",
    "license:make-keys": "node scripts/generateRsaKeys.js",
    "license:make-token": "node scripts/generateActivationToken.js --privkey ./license/private_key.pem --cred nemesis-EXAMPLE --license EXAMPLE --days 365"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@react-three/drei": "^9.114.3",
    "@react-three/fiber": "^8.17.10",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/supabase-js": "^2.86.0",
    "@tabler/icons-react": "^3.36.0",
    "@tailwindcss/postcss": "^4.1.18",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.2",
    "framer-motion": "^12.23.26",
    "gsap": "^3.14.2",
    "localtunnel": "^2.0.2",
    "next": "^14.2.35",
    "postcss": "^8.5.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.nemesis.app",
    "productName": "Nemesis Studio Generator Veo",
    "asar": false,
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!**/.next/cache/**",
      "!uploads/*.tmp",
      "electron/**",
      "!license/private_key.pem",
      "!scripts/generateActivationToken.js",
      "!scripts/generateRsaKeys.js"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Nemesis Studio"
    }
  }
}
